# TMDB API Configuration
# Get these from: https://www.themoviedb.org/settings/api

# Server-side API Read Access Token (v4 Auth)
# Required for server-side API calls (marked as secret in Vercel)
TMDB_READ_ACCESS_KEY=your_tmdb_read_access_token_here

# Client-side API Key (v3 Auth) 
# Required for client-side API calls (publicly exposed, safe with NEXT_PUBLIC prefix)
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
